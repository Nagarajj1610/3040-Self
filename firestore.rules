rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile rules: scoped to the specific user's authenticated UID
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Trips rules: scoped to trips where the userId in the document matches the authenticated user's UID
    match /trips/{tripId} {
      // For creation, we check the incoming data (request.resource.data)
      // For reading, editing, or deleting, we check the existing data (resource.data)
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
